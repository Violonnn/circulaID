{
  "expo": {
    "name": "",
    "slug": "CirculaID",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "circulaid",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.circulaid" 
    },
    "android": {
      "package": "com.yourcompany.circulaid",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CirculaID to access your photos so you can upload proof of work.",
          "cameraPermission": "Allow CirculaID to use the camera to take proof-of-work photos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow CirculaID to use your location to auto-fill your worker profile address."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow CirculaID to use the camera to scan job start/finish QR codes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
